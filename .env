# TestFlowAI starter .env
# Replace the placeholder API key before running.

# OpenAI (default provider)
OPENAI_API_KEY=your_openai_api_key_here

# Default model: cost-efficient OpenAI model
LLM_MODEL=gpt-5.4-mini

# Notes:
# - To use OpenAI-compatible providers, you can set LLM_API_KEY and LLM_BASE_URL instead.
# - For Azure OpenAI, set AZURE_OPENAI_ENDPOINT, AZURE_OPENAI_API_KEY, and AZURE_OPENAI_API_VERSION.