# TestFlowAI .env template
# 1) Copy this file to the project root and rename to ".env":
#    cp templates/.env.template .env
# 2) Fill in the values as needed.

# --- AI provider configuration ---
# Default: OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Optional: choose a model (defaults are fine for most cases)
LLM_MODEL=gpt-5.4-mini

# OpenAI-compatible providers (optional)
# Set these instead of OPENAI_API_KEY when using providers like OpenRouter/Groq/DeepSeek/Ollama
# LLM_API_KEY=your_provider_key_here
# LLM_BASE_URL=https://provider.example.com/openai/v1

# Azure OpenAI (optional)
# AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
# AZURE_OPENAI_API_KEY=your_azure_key
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# --- Browser options ---
# Show a visible browser by default; set to true for CI/headless servers
# HEADLESS=false

# Extra hardening to suppress any password/prompts UI (useful for demos)
# STRICT_NO_PASSWORD_UI=false

# --- Reliability tuning ---
# Selenium attempts per AI plan (default 5)
# SELENIUM_RETRIES=5
# Total AI planning attempts per step (default 2)
# AI_RETRIES=2
